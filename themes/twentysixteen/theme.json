{
  "$schema": "https://schemas.wp.org/wp/6.1/theme.json",
  "version": 1,
  "settings": {
    "color": {
      "palette": [
        { "slug": "dark-gray",   "color": "#1a1a1a", "name": "Dark Gray" },
        { "slug": "medium-gray", "color": "#686868", "name": "Medium Gray" },
        { "slug": "light-gray",  "color": "#e5e5e5", "name": "Light Gray" },
        { "slug": "white",       "color": "#ffffff", "name": "White" },
        { "slug": "blue",        "color": "#007acc", "name": "Blue" }
      ]
    },
    "layout": { "contentSize": "840px", "wideSize": "1200px" },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Source Sans Pro\", Calibri, Candara, Arial, sans-serif",
          "name": "Source Sans Pro",
          "slug": "source-sans-pro"
        },
        {
          "fontFamily": "Bitter, Georgia, \"Times New Roman\", serif",
          "name": "Bitter",
          "slug": "bitter"
        }
      ],
      "fontSizes": [
        { "slug": "small",  "size": "0.8125rem", "name": "Small" },
        { "slug": "medium", "size": "1rem",      "name": "Normal" },
        { "slug": "large",  "size": "1.3125rem", "name": "Large" },
        { "slug": "huge",   "size": "1.625rem",  "name": "Huge" }
      ]
    }
  }
}
