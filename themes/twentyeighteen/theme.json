        { "slug": "dark", "color": "#222", "name": "Dark" },
        { "slug": "medium-dark", "color": "#444", "name": "Medium Dark" },
        { "slug": "medium", "color": "#767676", "name": "Medium Gray" },
        { "slug": "light", "color": "#999", "name": "Light Gray" },
